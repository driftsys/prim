# .primignore — prim's committed escape hatch (gitignore syntax).
# Paths listed here are left byte-for-byte unchanged by prim.

# git-std generates CHANGELOG.md; prim must not hard-wrap generated content.
CHANGELOG.md

# Correctness-harness test fixtures intentionally contain non-canonical whitespace and line endings.
# These golden files must remain byte-exact and unformatted.
crates/prim-fmt/tests/correctness/fixtures/
